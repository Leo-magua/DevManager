{
  "app": {
    "name": "AllProject DevManager",
    "version": "1.0.0",
    "port": 81,
    "description": "统一管理 AllProject 下所有子项目的开发看板"
  },
  "projects_root": "/var/www/AllProject",
  "monitored_projects": [
    {
      "id": "personalwork",
