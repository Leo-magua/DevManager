# DevManager environment variables.
# Copy to .env (which is gitignored) and fill in.

# Bcrypt hash of the admin password. Generate with:
#   node -e 'console.log(require("bcryptjs").hashSync(process.argv[1], 10))' 'YOUR_PASSWORD'
ADMIN_PASSWORD_HASH=

# Shared secret required for worker/agent callback endpoints
# (POST /tasks/:id/{complete,fail}, POST /queue/{claim,complete,error,log}).
# Workers must send it as the X-Worker-Secret request header.
WORKER_SHARED_SECRET=

# Optional overrides
# PROJECTS_ROOT=/Users/you/AllProject
# NGINX_PREFIX=/opt/homebrew
# PERSONALWORK_PORT=3991
